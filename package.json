{
  "name": "desktop-monitor",
  "version": "1.0.4",
  "description": "실시간 데스크탑 성능 모니터링 대시보드",
  "main": "./out/main/index.js",
  "author": "david choi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/x77xdavid-prog/desktop-monitor.git"
  },
  "homepage": "./",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:win": "electron-vite build && electron-builder --win",
    "build:portable": "electron-vite build && electron-builder --win portable",
    "release": "electron-vite build && electron-builder --win --publish always",
    "release:draft": "electron-vite build && electron-builder --win --publish onTagOrDraft"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "systeminformation": "^5.23.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.14.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "zustand": "^5.0.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/node": "^22.10.2"
  }
}
